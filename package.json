{
  "name": "pennypilot",
  "version": "0.2.5",
  "description": "PennyPilot — AI copilot for French accounting firms on Pennylane. Monthly close memo in 8 seconds.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "test": "node --test 'test/*.test.js'",
    "test:auth": "node --env-file=.env -e \"import('./lib/pennylane-client.js').then(m=>m.getMe()).then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "pack": "bash scripts/build-bundle.sh",
    "pack:quick": "mcpb pack"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "HOLCO <alan@holco.co> (https://holco.co)",
  "repository": {
    "type": "git",
    "url": "https://github.com/holco-apps/pennypilot.git"
  },
  "homepage": "https://apps.holco.co/mcp/pennylane",
  "bugs": "https://github.com/holco-apps/pennypilot/issues",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2"
  }
}
